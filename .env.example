# Application
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://postgres:VetkaSotona666@localhost:5432/chat_system

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-here-please-change-in-production
